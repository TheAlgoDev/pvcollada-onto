# CQ08 — Which modules are bifacial, and what is their bifacial factor?
# Uses the pvc:ModuleType enumeration and pvc:bifacialFactor property.

PREFIX pvc:  <https://cwrusdle.bitbucket.io/mds/builtenv/pvcollada/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?module ?label ?bifacialFactor
WHERE {
    ?module a pvc:Module ;
            rdfs:label ?label ;
            pvc:hasModuleType pvc:Bifacial .
    OPTIONAL { ?module pvc:bifacialFactor ?bifacialFactor }
}
ORDER BY ?label
