    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/CentralInverter -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/CentralInverter">
        <rdf:type rdf:resource="https://w3id.org/pvcollada/InverterType"/>
        <rdfs:label xml:lang="en">central inverter</rdfs:label>
        <skos:altLabel xml:lang="en">central</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/CircularPost -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/CircularPost">
        <rdf:type rdf:resource="https://w3id.org/pvcollada/PostShape"/>
        <rdfs:label xml:lang="en">circular post</rdfs:label>
        <skos:altLabel xml:lang="en">circle</skos:altLabel>
    </owl:NamedIndividual>
    


