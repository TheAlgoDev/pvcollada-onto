<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/pvcollada/"
     xml:base="https://w3id.org/pvcollada/"
     xmlns:mds="https://cwrusdle.bitbucket.io/mds/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:qudt="http://qudt.org/schema/qudt/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:CommonCoreOntologies="http://www.ontologyrepository.com/CommonCoreOntologies/">
    <owl:Ontology rdf:about="https://w3id.org/pvcollada/">
        <owl:versionIRI rdf:resource="https://w3id.org/pvcollada/0.1.0"/>
        <owl:imports rdf:resource="https://cwrusdle.bitbucket.io/mds/"/>
        <CommonCoreOntologies:ont00001754 rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://github.com/ucf-photovoltaics/pv-ontology</CommonCoreOntologies:ont00001754>
        <rdfs:label xml:lang="en">PV-Collada Ontology</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.example.com/pvcollada"/>
        <skos:definition xml:lang="en">OWL 2 ontology derived from the PV-Collada 2.0 XSD schema. Provides vocabulary for PV system circuit topology, physical layout geometry, and component product data, within the MDS-Onto builtenv domain.</skos:definition>
        <skos:scopeNote xml:lang="en">Covers three interlocking layers: (1) a product library of typed PV components (modules, inverters, cables, etc.); (2) a circuit topology describing how those components are wired together; and (3) a physical 3-D layout associating circuit positions with geometric rack instances. ModuleLayout is the cross-domain bridge between layers 2 and 3.</skos:scopeNote>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://qudt.org/schema/qudt/applicableUnit -->


    <owl:AnnotationProperty rdf:about="http://qudt.org/schema/qudt/applicableUnit"/>
    


    <!-- http://www.ontologyrepository.com/CommonCoreOntologies/ont00001754 -->


    <owl:AnnotationProperty rdf:about="http://www.ontologyrepository.com/CommonCoreOntologies/ont00001754"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#closeMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#closeMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#scopeNote -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#scopeNote"/>
    


    <!-- https://cwrusdle.bitbucket.io/mds/hasDomain -->


    <owl:AnnotationProperty rdf:about="https://cwrusdle.bitbucket.io/mds/hasDomain"/>
    


    <!-- https://cwrusdle.bitbucket.io/mds/hasStudyStage -->


    <owl:AnnotationProperty rdf:about="https://cwrusdle.bitbucket.io/mds/hasStudyStage"/>
    


    <!-- https://cwrusdle.bitbucket.io/mds/hasSubDomain -->


    <owl:AnnotationProperty rdf:about="https://cwrusdle.bitbucket.io/mds/hasSubDomain"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/pvcollada/hasCableToNeighbor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasCableToNeighbor">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/OptimizerInstance"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/CableTo"/>
        <rdfs:label xml:lang="en">has cable to neighbor</rdfs:label>
        <skos:definition xml:lang="en">Associates an optimizer instance with the cable that daisy-chains it to an adjacent optimizer.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasCableToParent -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasCableToParent">
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/CableTo"/>
        <rdfs:label xml:lang="en">has cable to parent</rdfs:label>
        <skos:definition xml:lang="en">Associates a circuit instance with the cable that connects it to its electrical parent node.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasCellArchitecture -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasCellArchitecture">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Module"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/CellArchitecture"/>
        <rdfs:label xml:lang="en">has cell architecture</rdfs:label>
        <skos:definition xml:lang="en">Specifies the cell junction or contact architecture used in a module.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasCellMaterial -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasCellMaterial">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Module"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/CellMaterial"/>
        <rdfs:label xml:lang="en">has cell material</rdfs:label>
        <skos:definition xml:lang="en">Specifies the semiconductor absorber material of the cells in a module.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasConductorMaterial -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasConductorMaterial">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Cable"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/ConductorMaterial"/>
        <rdfs:label xml:lang="en">has conductor material</rdfs:label>
        <skos:definition xml:lang="en">Specifies the conductor material of a cable product.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasDCCombinerInput -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasDCCombinerInput">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/MPPTInput"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/DCCombinerInstance"/>
        <rdfs:label xml:lang="en">has DC combiner input</rdfs:label>
        <skos:definition xml:lang="en">Associates an MPPT input with a DC combiner that aggregates strings.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasDriveType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasDriveType">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Table"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/DriveType"/>
        <rdfs:label xml:lang="en">has drive type</rdfs:label>
        <skos:definition xml:lang="en">Associates a single-axis tracker table with its drive coupling type.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasEfficiencyStandardType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasEfficiencyStandardType">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Inverter"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/EfficiencyStandardType"/>
        <rdfs:label xml:lang="en">has efficiency standard type</rdfs:label>
        <skos:definition xml:lang="en">Specifies the rating standard (CEC or EU) used to compute the efficiency_standard_value.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasGapType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasGapType">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Gap"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/GapType"/>
        <rdfs:label xml:lang="en">has gap type</rdfs:label>
        <skos:definition xml:lang="en">Associates a gap with its function (motor or joint).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasInverterType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasInverterType">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Inverter"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/InverterType"/>
        <rdfs:label xml:lang="en">has inverter type</rdfs:label>
        <skos:definition xml:lang="en">Associates an inverter product with its deployment topology.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasMPPTInput -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasMPPTInput">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/InverterInstance"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/MPPTInput"/>
        <rdfs:label xml:lang="en">has MPPT input</rdfs:label>
        <skos:definition xml:lang="en">Associates a circuit inverter instance with its MPPT channel instances.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasMPPTUnit -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasMPPTUnit">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Inverter"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/MPPTUnit"/>
        <rdfs:label xml:lang="en">has MPPT unit</rdfs:label>
        <skos:definition xml:lang="en">Associates an inverter product with its MPPT channel specifications.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasModuleArray -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasModuleArray">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/String"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/ModuleArray"/>
        <rdfs:label xml:lang="en">has module array</rdfs:label>
        <skos:definition xml:lang="en">Associates a string with its module array (direct-wire configuration).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasModuleLayout -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasModuleLayout">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/ModuleArray"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/ModuleLayout"/>
        <rdfs:label xml:lang="en">has module layout</rdfs:label>
        <skos:definition xml:lang="en">Associates a module array with its constituent ModuleLayout entries, each describing the position of one module in the string and in the rack.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasModuleOrientation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasModuleOrientation">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/ModuleOrientation"/>
        <rdfs:label xml:lang="en">has module orientation</rdfs:label>
        <skos:definition xml:lang="en">Associates a rack with the mounting orientation of its modules.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasModuleType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasModuleType">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Module"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/ModuleType"/>
        <rdfs:label xml:lang="en">has module type</rdfs:label>
        <skos:definition xml:lang="en">Associates a module product with its form-factor type.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasOptimizerArray -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasOptimizerArray">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/String"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/OptimizerArray"/>
        <rdfs:label xml:lang="en">has optimizer array</rdfs:label>
        <skos:definition xml:lang="en">Associates a string with its optimizer array (optimized configuration).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasPostInclination -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasPostInclination">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Post"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/PostInclination"/>
        <rdfs:label xml:lang="en">has post inclination</rdfs:label>
        <skos:definition xml:lang="en">Associates a post with its installation inclination (vertical or perpendicular).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasPostShape -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasPostShape">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Post"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/PostShape"/>
        <rdfs:label xml:lang="en">has post shape</rdfs:label>
        <skos:definition xml:lang="en">Associates a post with its cross-section shape.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasPostType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasPostType">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Post"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/PostType"/>
        <rdfs:label xml:lang="en">has post type</rdfs:label>
        <skos:definition xml:lang="en">Associates a post with its structural function (rack, tracker, fence).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasPowerType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasPowerType">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Cable"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/PowerType"/>
        <rdfs:label xml:lang="en">has power type</rdfs:label>
        <skos:definition xml:lang="en">Associates a cable with its power type (AC or DC).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasRackType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasRackType">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/RackType"/>
        <rdfs:label xml:lang="en">has rack type</rdfs:label>
        <skos:definition xml:lang="en">Associates a rack with its mounting type (fixed_tilt or tracker).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasString -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasString">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/MPPTInput"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/String"/>
        <rdfs:label xml:lang="en">has string</rdfs:label>
        <skos:definition xml:lang="en">Associates an MPPT input with its connected PV strings.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasTableType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasTableType">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Table"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/TableType"/>
        <rdfs:label xml:lang="en">has table type</rdfs:label>
        <skos:definition xml:lang="en">Associates a table with its mounting type (fixed or tracker).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasTorqueTubeShape -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasTorqueTubeShape">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Table"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/TorqueTubeShape"/>
        <rdfs:label xml:lang="en">has torque tube shape</rdfs:label>
        <skos:definition xml:lang="en">Associates a single-axis tracker table with its torque tube cross-section shape.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/hasTrackerType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/hasTrackerType">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Table"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/TrackerType"/>
        <rdfs:label xml:lang="en">has tracker type</rdfs:label>
        <skos:definition xml:lang="en">Associates a tracker table with its axis configuration.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/referencesACCombinerProduct -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/referencesACCombinerProduct">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/ACCombinerInstance"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/ACCombiner"/>
        <rdfs:label xml:lang="en">references AC combiner product</rdfs:label>
        <skos:definition xml:lang="en">Links a circuit AC combiner instance to its product specification.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/referencesCableProduct -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/referencesCableProduct">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/CableTo"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/Cable"/>
        <rdfs:label xml:lang="en">references cable product</rdfs:label>
        <skos:definition xml:lang="en">Links a CableTo connection to the cable product it uses.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/referencesDCCombinerProduct -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/referencesDCCombinerProduct">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/DCCombinerInstance"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/DCCombiner"/>
        <rdfs:label xml:lang="en">references DC combiner product</rdfs:label>
        <skos:definition xml:lang="en">Links a circuit DC combiner instance to its product specification.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/referencesInverterProduct -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/referencesInverterProduct">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/InverterInstance"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/Inverter"/>
        <rdfs:label xml:lang="en">references inverter product</rdfs:label>
        <skos:definition xml:lang="en">Links a circuit inverter instance to its product specification.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/referencesModule -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/referencesModule">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/Module"/>
        <rdfs:label xml:lang="en">references module</rdfs:label>
        <skos:definition xml:lang="en">Links a rack to the module product specification it holds, via the module_id IDREF in the PV-Collada schema.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/referencesOptimizerProduct -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/referencesOptimizerProduct">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/OptimizerInstance"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/Optimizer"/>
        <rdfs:label xml:lang="en">references optimizer product</rdfs:label>
        <skos:definition xml:lang="en">Links a circuit optimizer instance to its product specification.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/referencesRack -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/referencesRack">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/ModuleLayout"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:label xml:lang="en">references rack</rdfs:label>
        <skos:definition xml:lang="en">Cross-domain bridge property: links a circuit ModuleLayout to the physical rack instance (via instance_rack_ref) that holds the module.</skos:definition>
        <skos:scopeNote xml:lang="en">This is the critical join between circuit topology and physical layout.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pvcollada/referencesTransformerProduct -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pvcollada/referencesTransformerProduct">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/TransformerInstance"/>
        <rdfs:range rdf:resource="https://w3id.org/pvcollada/Transformer"/>
        <rdfs:label xml:lang="en">references transformer product</rdfs:label>
        <skos:definition xml:lang="en">Links a circuit transformer instance to its product specification.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/pvcollada/azimuth -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/azimuth">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">rack azimuth</rdfs:label>
        <skos:definition xml:lang="en">Azimuth angle of a fixed rack (direction modules face).</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: °; applies to FixedTiltRack only.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/bifacialFactor -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/bifacialFactor">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Module"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">bifaciality factor</rdfs:label>
        <skos:definition xml:lang="en">Ratio of rear-side to front-side quantum efficiency for bifacial modules (dimensionless, 0–1).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/cableLength -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/cableLength">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/CableTo"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">cable length</rdfs:label>
        <skos:definition xml:lang="en">Installed length of this cable run.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: m (assumed SI default; verify against project file)</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/capacityAC -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/capacityAC">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Inverter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <qudt:applicableUnit rdf:resource="http://qudt.org/vocab/unit/W"/>
        <rdfs:label xml:lang="en">maximum AC capacity</rdfs:label>
        <skos:definition xml:lang="en">Maximum inverter AC output power.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: W</skos:scopeNote>
