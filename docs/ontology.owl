        <rdfs:label xml:lang="en">circular torque tube</rdfs:label>
        <skos:altLabel xml:lang="en">circle</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/CopperConductor -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/CopperConductor">
        <rdf:type rdf:resource="https://w3id.org/pvcollada/ConductorMaterial"/>
        <rdfs:label xml:lang="en">copper conductor</rdfs:label>
        <skos:altLabel xml:lang="en">copper</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/DCPower -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/DCPower">
