        <rdfs:label xml:lang="en">concentrating photovoltaic module</rdfs:label>
        <skos:altLabel xml:lang="en">cpv</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/CdTe -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/CdTe">
