    <!-- https://w3id.org/pvcollada/postDepth -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/postDepth">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Post"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">post underground depth</rdfs:label>
        <skos:definition xml:lang="en">Nominal depth of the post driven underground.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/postDiameter -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/postDiameter">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Post"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">post diameter</rdfs:label>
        <skos:definition xml:lang="en">Diameter of the post cross-section.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/postLength -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/postLength">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Post"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">post total length</rdfs:label>
        <skos:definition xml:lang="en">Total length of the post including the underground portion.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/productName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/productName">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">product name</rdfs:label>
        <skos:definition xml:lang="en">Model name of the product (e.g., &apos;Q.Tron Classic 440W&apos;).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/projectName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/projectName">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Project"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">project name</rdfs:label>
        <skos:definition xml:lang="en">Name of the PV project.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/rackColumn -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/rackColumn">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/ModuleLayout"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">rack column</rdfs:label>
        <skos:definition xml:lang="en">Column index of the module slot on the physical rack.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/rackOffset -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/rackOffset">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">rack offset</rdfs:label>
        <skos:definition xml:lang="en">Distance from the rack surface to the tracker torque tube centre.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/rackRow -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/rackRow">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/ModuleLayout"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">rack row</rdfs:label>
        <skos:definition xml:lang="en">Row index of the module slot on the physical rack.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/resistance -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/resistance">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Cable"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">resistance per unit length</rdfs:label>
        <skos:definition xml:lang="en">DC electrical resistance per kilometre of cable.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: Ω/km</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/rigid -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/rigid">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Gap"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label xml:lang="en">rigid</rdfs:label>
        <skos:definition xml:lang="en">True if the gap is rigid; false if it allows torque tube flexion.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/rowSpacing -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/rowSpacing">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">row spacing</rdfs:label>
        <skos:definition xml:lang="en">Spacing between modules in the row direction on a rack.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/selfConsumption -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/selfConsumption">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Inverter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <qudt:applicableUnit rdf:resource="http://qudt.org/vocab/unit/W"/>
        <rdfs:label xml:lang="en">self consumption</rdfs:label>
        <skos:definition xml:lang="en">Power consumed by the inverter during normal operation.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: W</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/slope -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/slope">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">rack slope</rdfs:label>
        <skos:definition xml:lang="en">Slope of a fixed rack in the direction 90° counterclockwise from azimuth.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: °</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/stringCount -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/stringCount">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Project"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:label xml:lang="en">string count</rdfs:label>
        <skos:definition xml:lang="en">Total number of series-connected module strings.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/systemCapacityAC -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/systemCapacityAC">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Project"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <qudt:applicableUnit rdf:resource="http://qudt.org/vocab/unit/W"/>
        <rdfs:label xml:lang="en">system AC capacity</rdfs:label>
        <skos:definition xml:lang="en">Total AC capacity at the inverter rating condition.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: W</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/systemCapacityDC -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/systemCapacityDC">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Project"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <qudt:applicableUnit rdf:resource="http://qudt.org/vocab/unit/W"/>
        <rdfs:label xml:lang="en">system DC capacity</rdfs:label>
        <skos:definition xml:lang="en">Total DC nameplate capacity of the PV system at STC.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: W</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/tCoefIsc -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/tCoefIsc">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Module"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">temperature coefficient of short-circuit current</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://cwrusdle.bitbucket.io/mds/ModuleTemperatureCoefficientCurrent"/>
        <skos:definition xml:lang="en">Change in short-circuit current per degree Celsius.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: A/°C</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/tCoefPower -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/tCoefPower">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Module"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">temperature coefficient of power</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://cwrusdle.bitbucket.io/mds/ModuleTemperatureCoefficientPower"/>
        <skos:definition xml:lang="en">Change in maximum power per degree Celsius.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: %/°C</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/tCoefVoc -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/tCoefVoc">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Module"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">temperature coefficient of open-circuit voltage</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://cwrusdle.bitbucket.io/mds/ModuleTemperatureCoefficientVoltage"/>
        <skos:definition xml:lang="en">Change in open-circuit voltage per degree Celsius.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: V/°C</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/tableCount -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/tableCount">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Project"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:label xml:lang="en">table count</rdfs:label>
        <skos:definition xml:lang="en">Total number of tables in the physical layout.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/tilt -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/tilt">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">rack tilt</rdfs:label>
        <skos:definition xml:lang="en">Tilt angle from horizontal of a fixed rack.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: °; applies to FixedTiltRack only.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/timezone -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/timezone">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Project"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">timezone</rdfs:label>
        <skos:definition xml:lang="en">IANA timezone string for the project location (e.g., &apos;America/Phoenix&apos;).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/timezoneOffset -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/timezoneOffset">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Project"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">timezone offset</rdfs:label>
        <skos:definition xml:lang="en">UTC offset in hours; positive values are East of UTC.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: h</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/trackerAzimuth -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/trackerAzimuth">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">tracker azimuth</rdfs:label>
        <skos:definition xml:lang="en">Azimuth of a tracker torque tube. Rotation is a right-hand rotation around this axis; e.g., positive rotation at azimuth 180° is westward.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: °; applies to TrackerRack only.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/trackerHeight -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/trackerHeight">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">tracker height</rdfs:label>
        <skos:definition xml:lang="en">Height of the tracker torque tube centre above ground.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/trackerMaxGapAngle -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/trackerMaxGapAngle">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Table"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">maximum gap angle</rdfs:label>
        <skos:definition xml:lang="en">Maximum angle formed in the torque axis at a gap between racks.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: °</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/trackerMaxRotation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/trackerMaxRotation">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Table"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">tracker maximum rotation</rdfs:label>
        <skos:definition xml:lang="en">Pair of values (negative, positive) giving the nominal maximum rotation angles from horizontal for a single-axis tracker, e.g., &apos;-45 45&apos;.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: °; encoded as two space-separated floats.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/trackerSlope -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/trackerSlope">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">tracker slope</rdfs:label>
        <skos:definition xml:lang="en">Slope of a tracker torque tube in the direction of its azimuth.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: °</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/trackerTorqueTubeDiameter -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/trackerTorqueTubeDiameter">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Table"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">torque tube diameter</rdfs:label>
        <skos:definition xml:lang="en">Nominal diameter of the single-axis tracker torque tube.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/triangleCount -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/triangleCount">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Terrain"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:label xml:lang="en">triangle count</rdfs:label>
        <skos:definition xml:lang="en">Number of triangular faces in the terrain surface mesh.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/vIn -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/vIn">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Transformer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <qudt:applicableUnit rdf:resource="http://qudt.org/vocab/unit/V"/>
        <rdfs:label xml:lang="en">nominal input voltage</rdfs:label>
        <skos:definition xml:lang="en">Nominal AC input voltage of the transformer.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: V</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/vMpp -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/vMpp">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Module"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <qudt:applicableUnit rdf:resource="http://qudt.org/vocab/unit/V"/>
        <rdfs:label xml:lang="en">voltage at maximum power point at STC</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://cwrusdle.bitbucket.io/mds/VoltageAtMaximumPower"/>
        <skos:definition xml:lang="en">Module voltage at the maximum power point under STC.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: V</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/vMppMax -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/vMppMax">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <qudt:applicableUnit rdf:resource="http://qudt.org/vocab/unit/V"/>
        <rdfs:label xml:lang="en">maximum MPPT voltage</rdfs:label>
        <skos:definition xml:lang="en">Maximum DC voltage for MPPT tracking.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: V</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/vMppMin -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/vMppMin">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <qudt:applicableUnit rdf:resource="http://qudt.org/vocab/unit/V"/>
        <rdfs:label xml:lang="en">minimum MPPT voltage</rdfs:label>
        <skos:definition xml:lang="en">Minimum DC voltage for MPPT tracking.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: V</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/vMppNom -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/vMppNom">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <qudt:applicableUnit rdf:resource="http://qudt.org/vocab/unit/V"/>
        <rdfs:label xml:lang="en">nominal MPPT voltage</rdfs:label>
        <skos:definition xml:lang="en">Nominal DC voltage for MPPT tracking.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: V</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/vOc -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/vOc">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Module"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <qudt:applicableUnit rdf:resource="http://qudt.org/vocab/unit/V"/>
        <rdfs:label xml:lang="en">open-circuit voltage at STC</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://cwrusdle.bitbucket.io/mds/NameplateOpenCircuitVoltage"/>
        <rdfs:seeAlso rdf:resource="https://cwrusdle.bitbucket.io/mds/OpenCircuitVoltage"/>
        <skos:definition xml:lang="en">Module open-circuit voltage at Standard Test Conditions.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: V</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/vOut -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/vOut">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Transformer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <qudt:applicableUnit rdf:resource="http://qudt.org/vocab/unit/V"/>
        <rdfs:label xml:lang="en">nominal output voltage</rdfs:label>
        <skos:definition xml:lang="en">Nominal AC output voltage of the transformer.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: V</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/vOutAC -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/vOutAC">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Inverter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <qudt:applicableUnit rdf:resource="http://qudt.org/vocab/unit/V"/>
        <rdfs:label xml:lang="en">nominal AC output voltage</rdfs:label>
        <skos:definition xml:lang="en">Nominal AC output voltage of the inverter.</skos:definition>
        <skos:scopeNote xml:lang="en">Unit: V</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pvcollada/vertexCount -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pvcollada/vertexCount">
        <rdfs:domain rdf:resource="https://w3id.org/pvcollada/Terrain"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:label xml:lang="en">vertex count</rdfs:label>
        <skos:definition xml:lang="en">Number of vertices in the triangulated terrain surface mesh.</skos:definition>
    </owl:DatatypeProperty>
    


