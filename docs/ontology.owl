        <rdfs:label xml:lang="en">CEC efficiency standard</rdfs:label>
        <skos:altLabel xml:lang="en">CEC</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/CPV -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/CPV">
