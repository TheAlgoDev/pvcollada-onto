    <!-- https://w3id.org/pvcollada/ACCombiner -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/ACCombiner">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVComponent"/>
        <rdfs:label xml:lang="en">AC Combiner Product</rdfs:label>
        <skos:definition xml:lang="en">Product-level specification for an AC inverter combiner panel.</skos:definition>
        <skos:scopeNote xml:lang="en">Corresponds to combiner_ac_type_object.</skos:scopeNote>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Characterization</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/ACCombinerInstance -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/ACCombinerInstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/CircuitInstance"/>
        <rdfs:label xml:lang="en">AC Combiner Instance</rdfs:label>
        <skos:definition xml:lang="en">An instance of an AC combiner panel in the electrical circuit.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/Cable -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/Cable">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVComponent"/>
        <rdfs:label xml:lang="en">Cable Product</rdfs:label>
        <skos:definition xml:lang="en">Product-level specification for a PV cable, including cross-sectional area, conductor count, material, and electrical resistance.</skos:definition>
        <skos:scopeNote xml:lang="en">Corresponds to cable_type_object.</skos:scopeNote>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Characterization</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/CableTo -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/CableTo">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/CircuitInstance"/>
        <rdfs:label xml:lang="en">Cable To</rdfs:label>
        <skos:definition xml:lang="en">A directed cable connection from a circuit instance to its electrical parent, carrying a reference to the cable product and the installed length.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/CellArchitecture -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/CellArchitecture">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/Heterojunction"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/IBC"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/PERC"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/SingleJunction"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/TOPcon"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/TandemPerovskite"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Cell Architecture</rdfs:label>
        <skos:closeMatch rdf:resource="https://cwrusdle.bitbucket.io/mds/CellTechnology"/>
        <skos:closeMatch rdf:resource="https://cwrusdle.bitbucket.io/mds/CellTechnologyType"/>
        <skos:definition xml:lang="en">Enumeration of cell junction or contact architectures used in PV modules.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Characterization</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/CellMaterial -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/CellMaterial">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/ASi"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/CdTe"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/MonoSi"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/PolySi"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Cell Material</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of absorber semiconductor materials used in PV cells.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Characterization</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/Circuit -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/Circuit">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/CircuitInstance"/>
        <rdfs:label xml:lang="en">Circuit</rdfs:label>
        <skos:definition xml:lang="en">The complete electrical circuit description of a PV system, rooted at a single circuit_root element that is a transformer, AC combiner, or inverter.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/CircuitInstance -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/CircuitInstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Circuit Instance</rdfs:label>
        <skos:definition xml:lang="en">An instantiated element in the electrical circuit topology of a PV system, referencing a PVComponent product specification.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/ConductorMaterial -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/ConductorMaterial">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/AluminumConductor"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/CopperConductor"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Conductor Material</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of cable conductor materials.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/DCCombiner -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/DCCombiner">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVComponent"/>
        <rdfs:label xml:lang="en">DC Combiner Product</rdfs:label>
        <skos:definition xml:lang="en">Product-level specification for a DC string combiner box.</skos:definition>
        <skos:scopeNote xml:lang="en">Corresponds to combiner_dc_type_object.</skos:scopeNote>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Characterization</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/DCCombinerInstance -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/DCCombinerInstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/CircuitInstance"/>
        <rdfs:label xml:lang="en">DC Combiner Instance</rdfs:label>
        <skos:definition xml:lang="en">An instance of a DC combiner box in the electrical circuit.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/DriveType -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/DriveType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/IndependentDrive"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/LinkedDrive"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Drive Type</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of drive coupling configurations for single-axis trackers.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/EfficiencyStandardType -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/EfficiencyStandardType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/CECEfficiency"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/EUEfficiency"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Efficiency Standard Type</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of rating standards used for inverter efficiency measurement.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/FixedTiltRack -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/FixedTiltRack">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pvcollada/hasRackType"/>
                <owl:hasValue rdf:resource="https://w3id.org/pvcollada/FixedTilt"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pvcollada/azimuth"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pvcollada/tilt"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/pvcollada/TrackerRack"/>
        <rdfs:label xml:lang="en">Fixed Tilt Rack</rdfs:label>
        <skos:definition xml:lang="en">A rack mounted at a fixed tilt angle; requires azimuth and tilt, and must not carry tracker geometry fields.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/Gap -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/Gap">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PhysicalAsset"/>
        <rdfs:label xml:lang="en">Tracker Gap</rdfs:label>
        <skos:definition xml:lang="en">A space between two racks on a single-axis tracker torque tube, occupied by a motor drive or a flexible joint.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/GapType -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/GapType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/JointGap"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/MotorGap"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Gap Type</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of gap categories between racks on a tracker torque tube.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/Inverter -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/Inverter">
        <rdfs:subClassOf rdf:resource="https://cwrusdle.bitbucket.io/mds/Inverter"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVComponent"/>
        <rdfs:label xml:lang="en">PV Inverter Product</rdfs:label>
        <skos:definition xml:lang="en">Product-level specification for a PV inverter, capturing its AC/DC power ratings, MPPT voltage window, efficiency, and parasitic consumption.</skos:definition>
        <skos:scopeNote xml:lang="en">Corresponds to inverter_type_object. Declared as a subclass of mds:Inverter to align with MDS-Onto.</skos:scopeNote>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Characterization</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/InverterInstance -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/InverterInstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/CircuitInstance"/>
        <rdfs:label xml:lang="en">Inverter Instance</rdfs:label>
        <skos:definition xml:lang="en">An instance of an inverter in the electrical circuit, referencing a product inverter specification and containing MPPT inputs.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/InverterType -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/InverterType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/CentralInverter"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/Microinverter"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/StringInverter"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Inverter Type</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of PV inverter deployment topologies.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/MPPTInput -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/MPPTInput">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/CircuitInstance"/>
        <rdfs:label xml:lang="en">MPPT Input</rdfs:label>
        <skos:definition xml:lang="en">A single MPPT channel instance within an inverter circuit instance, containing one or more strings or DC combiners.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/MPPTUnit -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/MPPTUnit">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVComponent"/>
        <rdfs:label xml:lang="en">MPPT Unit Product</rdfs:label>
        <skos:definition xml:lang="en">Product-level specification for a single maximum-power-point-tracking channel on an inverter, recording the number of parallel input strings.</skos:definition>
        <skos:scopeNote xml:lang="en">Corresponds to mppt_type_object.</skos:scopeNote>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Characterization</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/Module -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/Module">
        <rdfs:subClassOf rdf:resource="https://cwrusdle.bitbucket.io/mds/PhotovoltaicModule"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVComponent"/>
        <rdfs:label xml:lang="en">PV Module Product</rdfs:label>
        <skos:definition xml:lang="en">Product-level specification for a PV module, capturing its physical dimensions, electrical parameters at STC, and cell technology.</skos:definition>
        <skos:scopeNote xml:lang="en">Corresponds to module_type_object in pvcollada_schema_2.0.xsd. Declared as a subclass of mds:PhotovoltaicModule to align with the MDS-Onto builtenv PV-module hierarchy.</skos:scopeNote>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Characterization</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/ModuleArray -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/ModuleArray">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/CircuitInstance"/>
        <rdfs:label xml:lang="en">Module Array</rdfs:label>
        <skos:definition xml:lang="en">An ordered collection of modules within a string, each described by a ModuleLayout that maps a circuit position to a physical rack cell.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/ModuleLayout -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/ModuleLayout">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/CircuitInstance"/>
        <rdfs:label xml:lang="en">Module Layout</rdfs:label>
        <skos:definition xml:lang="en">Cross-domain bridge entity that maps a module&apos;s position in the electrical circuit (position_in_string) to its physical location on a rack (row, column) via a reference to an instance_rack_ref.</skos:definition>
        <skos:scopeNote xml:lang="en">This is the key join point between circuit topology and physical 3-D layout in PV-Collada.</skos:scopeNote>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/ModuleOrientation -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/ModuleOrientation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/Landscape"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/Portrait"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Module Orientation</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of module mounting orientations on a rack.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/ModuleType -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/ModuleType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/Bifacial"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/CPV"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/Monofacial"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/Shingle"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Module Type</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of PV module form-factor types.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/Optimizer -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/Optimizer">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVComponent"/>
        <rdfs:label xml:lang="en">Power Optimizer Product</rdfs:label>
        <skos:definition xml:lang="en">Product-level specification for a module-level power optimizer.</skos:definition>
        <skos:scopeNote xml:lang="en">Corresponds to optimizer_type_object.</skos:scopeNote>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Characterization</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/OptimizerArray -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/OptimizerArray">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/CircuitInstance"/>
        <rdfs:label xml:lang="en">Optimizer Array</rdfs:label>
        <skos:definition xml:lang="en">An ordered collection of power optimizer instances within a string.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/OptimizerInstance -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/OptimizerInstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/CircuitInstance"/>
        <rdfs:label xml:lang="en">Optimizer Instance</rdfs:label>
        <skos:definition xml:lang="en">An instance of a power optimizer in the circuit, connected via cable_to_parent and optionally cable_to_neighbor.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/PVColladaEntity -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/PVColladaEntity">
        <rdfs:label xml:lang="en">PV-Collada Entity</rdfs:label>
        <skos:definition xml:lang="en">Abstract root class for all entities described in the PV-Collada schema.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/PVComponent -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/PVComponent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">PV Component</rdfs:label>
        <skos:definition xml:lang="en">A typed product specification for a physical PV balance-of-system component, as declared in the PV-Collada components library.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Characterization</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/PhysicalAsset -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/PhysicalAsset">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Physical Asset</rdfs:label>
        <skos:definition xml:lang="en">A physical or geometric object in the 3-D layout of a PV installation, represented in the COLLADA scene graph.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/Post -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/Post">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PhysicalAsset"/>
        <rdfs:label xml:lang="en">Structural Post</rdfs:label>
        <skos:definition xml:lang="en">A vertical structural member that supports a rack, tracker torque tube, or fence, driven into or anchored to the ground.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/PostInclination -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/PostInclination">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/PerpendicularPost"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/VerticalPost"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Post Inclination</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of post installation inclination modes.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/PostShape -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/PostShape">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/CircularPost"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/HShapePost"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/RectangularPost"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Post Shape</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of structural post cross-section shapes.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/PostType -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/PostType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/FencePost"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/RackPost"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/TrackerPost"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Post Type</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of structural post functions.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/PowerType -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/PowerType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/ACPower"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/DCPower"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Power Type</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of electrical power type (AC or DC) for cables.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/Project -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/Project">
        <rdfs:subClassOf rdf:resource="https://cwrusdle.bitbucket.io/mds/PhotovoltaicSite"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PhysicalAsset"/>
        <rdfs:label xml:lang="en">PV Project</rdfs:label>
        <skos:definition xml:lang="en">Top-level project metadata for a PV-Collada file, recording system capacity, string and module counts, geographic projection, and boundary.</skos:definition>
        <skos:scopeNote xml:lang="en">Declared as a subclass of mds:PhotovoltaicSite; the pvc:Project adds schema-level attributes (capacity, module/string counts, projection).</skos:scopeNote>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/Rack -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/Rack">
        <rdfs:subClassOf rdf:resource="https://cwrusdle.bitbucket.io/mds/Racking"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PhysicalAsset"/>
        <rdfs:label xml:lang="en">PV Rack</rdfs:label>
        <skos:definition xml:lang="en">A co-planar group of modules mounted in a fixed or tracker configuration, described by a COLLADA geometry rectangle representing the rack surface.</skos:definition>
        <skos:scopeNote xml:lang="en">Declared as a subclass of mds:Racking. Business rule (Schematron): if rack_type = fixed_tilt then azimuth and tilt are required and tracker fields are forbidden; if rack_type = tracker then tracker_azimuth is required and fixed-tilt fields are forbidden. See pvc:FixedTiltRack and pvc:TrackerRack subclasses.</skos:scopeNote>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/RackType -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/RackType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/FixedTilt"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/TrackerRackType"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Rack Type</rdfs:label>
        <skos:closeMatch rdf:resource="https://cwrusdle.bitbucket.io/mds/RackingType"/>
        <skos:definition xml:lang="en">Enumeration of rack mounting strategies.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/String -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/String">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/CircuitInstance"/>
        <rdfs:label xml:lang="en">PV String</rdfs:label>
        <skos:definition xml:lang="en">A series-connected string of PV modules, containing either a module array or an optimizer array.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/Table -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/Table">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PhysicalAsset"/>
        <rdfs:label xml:lang="en">PV Table</rdfs:label>
        <skos:definition xml:lang="en">A group of mechanically linked racks in a single row, potentially including posts and gaps. When the table is a tracker, all constituent racks share the same rotation around the tracker axis.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/TableType -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/TableType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/FixedTable"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/TrackerTable"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Table Type</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of table mounting types.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/Terrain -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/Terrain">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PhysicalAsset"/>
        <rdfs:label xml:lang="en">Terrain</rdfs:label>
        <skos:definition xml:lang="en">A triangulated 3-D surface model representing the site terrain.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/TorqueTubeShape -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/TorqueTubeShape">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/CircularTube"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/OctagonalTube"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/RectangularTube"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Torque Tube Shape</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of cross-sectional shapes for a single-axis tracker torque tube.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/TrackerRack -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/TrackerRack">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/Rack"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pvcollada/hasRackType"/>
                <owl:hasValue rdf:resource="https://w3id.org/pvcollada/TrackerRackType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pvcollada/trackerAzimuth"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Tracker Rack</rdfs:label>
        <skos:definition xml:lang="en">A rack mounted on a solar tracker; requires tracker_azimuth, and must not carry fixed-tilt geometry fields.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/TrackerType -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/TrackerType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/DualAxisTracker"/>
                    <rdf:Description rdf:about="https://w3id.org/pvcollada/SingleAxisTracker"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVColladaEntity"/>
        <rdfs:label xml:lang="en">Tracker Type</rdfs:label>
        <skos:definition xml:lang="en">Enumeration of solar tracker axis configurations.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/Transformer -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/Transformer">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/PVComponent"/>
        <rdfs:label xml:lang="en">Transformer Product</rdfs:label>
        <skos:definition xml:lang="en">Product-level specification for an AC step-up or isolation transformer, including rated power, voltage ratio, efficiency, and loss parameters.</skos:definition>
        <skos:scopeNote xml:lang="en">Corresponds to transformer_type_object.</skos:scopeNote>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Characterization</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- https://w3id.org/pvcollada/TransformerInstance -->


    <owl:Class rdf:about="https://w3id.org/pvcollada/TransformerInstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pvcollada/CircuitInstance"/>
        <rdfs:label xml:lang="en">Transformer Instance</rdfs:label>
        <skos:definition xml:lang="en">An instance of a transformer in the electrical circuit.</skos:definition>
        <mds:hasDomain>builtenv</mds:hasDomain>
        <mds:hasStudyStage>Simulation</mds:hasStudyStage>
        <mds:hasSubDomain>pvcollada</mds:hasSubDomain>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


