        <rdfs:label xml:lang="en">direct current</rdfs:label>
        <skos:altLabel xml:lang="en">dc</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/DualAxisTracker -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/DualAxisTracker">
        <rdf:type rdf:resource="https://w3id.org/pvcollada/TrackerType"/>
        <rdfs:label xml:lang="en">dual axis tracker</rdfs:label>
        <skos:altLabel xml:lang="en">dual_axis</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/EUEfficiency -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/EUEfficiency">
        <rdf:type rdf:resource="https://w3id.org/pvcollada/EfficiencyStandardType"/>
        <rdfs:label xml:lang="en">EU efficiency standard</rdfs:label>
        <skos:altLabel xml:lang="en">EU</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/FencePost -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/FencePost">
        <rdf:type rdf:resource="https://w3id.org/pvcollada/PostType"/>
        <rdfs:label xml:lang="en">fence post</rdfs:label>
        <skos:altLabel xml:lang="en">fence</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/FixedTable -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/FixedTable">
        <rdf:type rdf:resource="https://w3id.org/pvcollada/TableType"/>
        <rdfs:label xml:lang="en">fixed table</rdfs:label>
        <skos:altLabel xml:lang="en">fixed</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/FixedTilt -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/FixedTilt">
        <rdf:type rdf:resource="https://w3id.org/pvcollada/RackType"/>
        <rdfs:label xml:lang="en">fixed tilt</rdfs:label>
        <skos:altLabel xml:lang="en">fixed_tilt</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/HShapePost -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/HShapePost">
        <rdf:type rdf:resource="https://w3id.org/pvcollada/PostShape"/>
        <rdfs:label xml:lang="en">H-shape post</rdfs:label>
        <skos:altLabel xml:lang="en">h-shape</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/Heterojunction -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/Heterojunction">
        <rdf:type rdf:resource="https://w3id.org/pvcollada/CellArchitecture"/>
        <rdfs:label xml:lang="en">heterojunction</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/IBC -->


