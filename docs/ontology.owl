        <rdfs:label xml:lang="en">bifacial module</rdfs:label>
        <skos:altLabel xml:lang="en">bifacial</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pvcollada/CECEfficiency -->


    <owl:NamedIndividual rdf:about="https://w3id.org/pvcollada/CECEfficiency">
