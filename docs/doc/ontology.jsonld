  "@id" : "https://cwrusdle.bitbucket.io/mds/builtenv/pvcollada/",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/ont00001754" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "https://github.com/ucf-photovoltaics/pv-ontology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PV-Collada Ontology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "http://www.example.com/pvcollada"
  } ],
  "http://www.w3.org/2002/07/owl#imports" : [ {
    "@id" : "https://cwrusdle.bitbucket.io/mds/"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://cwrusdle.bitbucket.io/mds/builtenv/pvcollada/0.1.0"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "OWL 2 ontology derived from the PV-Collada 2.0 XSD schema. Provides vocabulary for PV system circuit topology, physical layout geometry, and component product data, within the MDS-Onto builtenv domain."
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "Covers three interlocking layers: (1) a product library of typed PV components (modules, inverters, cables, etc.); (2) a circuit topology describing how those components are wired together; and (3) a physical 3-D layout associating circuit positions with geometric rack instances. ModuleLayout is the cross-domain bridge between layers 2 and 3."
  } ]
}, {
